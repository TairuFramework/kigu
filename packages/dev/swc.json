{
  "$schema": "https://swc.rs/schema.json",
  "jsc": {
    "parser": {
      "syntax": "typescript"
    },
    "target": "esnext",
    "transform": {
      "optimizer": {
        "globals": {
          "envs": ["NODE_ENV"]
        }
      },
      "react": {
        "runtime": "automatic"
      }
    }
  }
}
